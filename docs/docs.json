{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SchedKit",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#DFFF00",
    "light": "#DFFF00",
    "dark": "#a8bf00"
  },
  "navbar": {
    "links": [
      { "label": "Dashboard", "href": "https://schedkit.net/dashboard" }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://schedkit.net"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart", "authentication", "errors"]
          },
          {
            "group": "Platform",
            "pages": ["architecture", "infrastructure"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/signals",
              "concepts/beacon",
              "concepts/assignments",
              "concepts/incidents",
              "concepts/units"
            ]
          },
          {
            "group": "AI Integration",
            "pages": ["agent-tool-guide"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api-reference/auth",
              "api-reference/users",
              "api-reference/bookings",
              "api-reference/signals",
              "api-reference/tickets",
              "api-reference/orgs",
              "api-reference/push",
              "api-reference/webhooks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        { "anchor": "Live API Explorer", "href": "https://schedkit.net/docs", "icon": "terminal" },
        { "anchor": "GitHub", "href": "https://github.com/projectseven-co-ltd/schedkit", "icon": "github" },
        { "anchor": "Status", "href": "https://schedkit.net", "icon": "signal" }
      ]
    }
  },
  "openapi": "https://schedkit.net/docs/json",
  "footer": {
    "socials": {
      "github": "https://github.com/projectseven-co-ltd/schedkit"
    }
  }
}

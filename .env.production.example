# Portainer / Plesk production — copy to .env.production on the host (gitignored)
# or paste these keys into the Portainer stack Environment variables UI.
#
# See .env.example for full documentation (including VAPID, Mailjet, Stripe).

POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=schedkit
POSTGRES_USER=schedkit

# GHCR image (published on push to main). CI webhook sets IMAGE_TAG to short SHA.
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=projectseven-co-ltd
IMAGE_TAG=latest

API_SECRET=change-me-to-a-long-random-string
BASE_DOMAIN=schedkit.net
PLATFORM_ADMIN_EMAILS=ceo@schedkit.net

# SignalForge hub :3000, peer :3001 (CLIENT_PORT). SchedKit :3002 (SCHEDKIT_CLIENT_PORT).
SCHEDKIT_CLIENT_PORT=3002

# DATABASE_URL is auto-built by docker-compose.plesk.yml — only set if using external Postgres.
# DATABASE_URL=postgres://schedkit:PASSWORD@postgres:5432/schedkit?sslmode=disable

MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
MJ_FROM_EMAIL=noreply@schedkit.net
MJ_FROM_NAME=SchedKit

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ceo@schedkit.net

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_AGENCY=

NTFY_TOPIC=schedkit-leads

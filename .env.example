# SchedKit environment variables
# Copy to .env for local/docker compose, or set in Portainer stack env.
# Never commit real secrets (.env, .env.production).

# =============================================================================
# REQUIRED — core app
# =============================================================================

PORT=3000
# Public hostname for links in emails, booking URLs, magic links (no https://)
BASE_DOMAIN=schedkit.net
# Full public base URL for work order portal links and PDF footers (optional)
# PUBLIC_BASE_URL=https://schedkit.net
# Admin API header x-admin-secret — create user, bootstrap ops
API_SECRET=change-me-to-a-long-random-string
# Comma-separated emails that see the Platform admin panel in the dashboard
PLATFORM_ADMIN_EMAILS=ceo@schedkit.net

# Mobile password login (default enabled). Set false to disable POST /v1/auth/login
# AUTH_PASSWORD_LOGIN_ENABLED=true

# Planned maintenance — serves maintenance.html (503) for all routes except /health and /version
# MAINTENANCE_MODE=true

# =============================================================================
# REQUIRED — Postgres (default; omit NOCO_* entirely)
# =============================================================================
# Local docker compose: host port 5433 → postgres container 5432
# Portainer: leave DATABASE_URL unset — docker-compose.plesk.yml builds it from POSTGRES_*

DATABASE_URL=postgres://schedkit:schedkit@localhost:5433/schedkit?sslmode=disable
POSTGRES_DB=schedkit
POSTGRES_USER=schedkit
POSTGRES_PASSWORD=change-me-strong

# =============================================================================
# Docker / Portainer compose only (not read by Node directly)
# =============================================================================

# Same Portainer host as SignalForge hub (:3000) and peer (:3001).
# SchedKit stack uses SCHEDKIT_CLIENT_PORT — never CLIENT_PORT (that is SF's variable).
APP_PORT=3000
SCHEDKIT_CLIENT_PORT=3002
POSTGRES_PORT=5433
# BUILD_DATE=2026-06-13T00:00:00Z
# API_IMAGE=ghcr.io/projectseven-co-ltd/schedkit-api:latest
# IMAGE_REGISTRY=ghcr.io
# IMAGE_NAMESPACE=projectseven-co-ltd
# IMAGE_TAG=latest

# =============================================================================
# OPTIONAL — email (Mailjet) — magic links, booking confirmations, tickets
# Without these, login/booking emails are skipped (app still runs).
# =============================================================================

MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
MJ_FROM_EMAIL=noreply@schedkit.net
MJ_FROM_NAME=SchedKit

# =============================================================================
# OPTIONAL — Web Push (VAPID)
# =============================================================================
# VAPID = Voluntary Application Server Identification — the key pair that lets
# SchedKit send browser/PWA push notifications (new incident, SLA breach, etc.)
# to subscribed dashboard users. Without these, push is disabled silently.
#
# Generate a key pair once (from repo root, after npm install):
#   node -e "const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))"
#
# VAPID_SUBJECT must be a mailto: or https: URL identifying your app (contact).

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ceo@schedkit.net

# =============================================================================
# OPTIONAL — Google Calendar sync (Settings → Connect Google)
# =============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# OPTIONAL — Stripe billing (paid plans)
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_1TBMFk3LrZftF9HcDVGFbeMk
STRIPE_PRICE_AGENCY=price_1TBMFl3LrZftF9HcGXioTpJ2

# =============================================================================
# OPTIONAL — ntfy.sh alerts (signup notifications, critical incidents)
# =============================================================================

NTFY_TOPIC=schedkit-leads
NTFY_DEFAULT_TOPIC=

# =============================================================================
# OPTIONAL — Project Seven client portal
# =============================================================================
# Cookie domain — only if clients hit SchedKit directly (not via projectseven schedkit.php proxy).
# Leave UNSET when using the PHP proxy; it rewrites cookies to projectseven.us.
# PORTAL_COOKIE_DOMAIN=.projectseven.us
# Set false for local HTTP dev (default true when unset on production HTTPS)
# COOKIE_SECURE=false
# Org slug for Project Seven client portal (auto-created on API startup)
# PORTAL_ORG_SLUG=projectseven
# PORTAL_ORG_NAME=Project Seven
# PORTAL_ORG_OWNER_EMAIL=ceo@projectseven.us
# (Org + ticket departments are created automatically on API startup when PORTAL_ORG_SLUG is set)
# Leave PORTAL_COOKIE_DOMAIN unset when using projectseven.us schedkit.php proxy

# NOCO_URL=https://noco.app.p7n.net
# NOCO_TOKEN=
# NOCO_BASE_ID=
